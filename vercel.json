{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://viewed-history-app-production.up.railway.app/api/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://viewed-history-app-production.up.railway.app/socket.io/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
